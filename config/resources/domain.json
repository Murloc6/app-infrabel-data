{
  "version": "0.1",
  "prefixes": {
    "era": "http://data.europa.eu/949/",
    "gsp": "http://www.opengis.net/ont/geosparql#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "time": "http://www.w3.org/2006/time#"
  },
  "resources": {
    "geometries": {
      "name": "geometry",
      "class": "gsp:Geometry",
      "attributes": {
        "asWKT": {
          "type": "string",
          "predicate": "gsp:asWKT"
        }
      },
      "features": ["include-uri"],
      "new-resource-base": "http://data.europa.eu/949/"
    },
    "net-elements": {
      "name": "net-element",
      "class": "era:NetElement",
      "features": ["include-uri"],
      "new-resource-base": "http://data.europa.eu/949/",
      "attributes": {
        "begin-validity": {
          "type": "date",
          "predicate": "era:validity/time:hasBeginning/time:inXSDDate"
        },
        "end-validity": {
          "type": "date",
          "predicate": "era:validity/time:hasEnd/time:inXSDDate"
        }
      },
      "relationships": {
        "geometries": {
          "predicate": "gsp:hasGeometry",
          "target": "geometry",
          "cardinality": "one"
        }
      }
    },
    "linear-elements": {
      "name": "linear-element",
      "class": "era:LinearElement",
      "super": ["net-element"],
      "attributes": {
        "canonical-uri": {
          "type": "string",
          "predicate": "era:canonicalURI"
        },
        "label": {
          "type": "string",
          "predicate": "rdfs:label"
        }
      },
      "features": ["include-uri"],
      "new-resource-base": "http://data.europa.eu/949/"
    }
  }
}
